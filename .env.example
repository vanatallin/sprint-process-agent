# Sprint Agent Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Frontend (Vite)
# ===================

# Backend API endpoint (API Gateway URL)
VITE_API_URL=https://your-api-gateway-url.execute-api.us-east-1.amazonaws.com/dev

# ===================
# Backend (Lambda)
# ===================
# Note: These are stored in AWS SSM Parameter Store, not in .env
# Documented here for reference:
#
# /sprint-poc/dev/claude-api-key    - Anthropic API key for Claude
# /sprint-poc/dev/jira-board-id     - Jira board ID to analyze
# /sprint-poc/dev/refinement-doc-id - Google Doc ID for refinement notes
# /sprint-poc/dev/tech-design-doc-id - Google Doc ID for tech design

# ===================
# Local Development
# ===================

# Node environment (development, production, test)
NODE_ENV=development

# Frontend dev server port (optional, defaults to 3000)
# VITE_PORT=3000
