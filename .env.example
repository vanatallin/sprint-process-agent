# Sprint Agent Environment Configuration
# Copy this file to .env and fill in your values

# ===================
# Frontend (Vite)
# ===================

# Backend API endpoint
# For local development: http://localhost:3001
# For production: Your API Gateway URL
VITE_API_URL=http://localhost:3001

# ===================
# Local Development
# ===================

# Node environment (development, production, test)
NODE_ENV=development

# ===================
# Storage (S3 / MinIO)
# ===================

# S3 bucket name for storing analysis results
S3_BUCKET=sprint-agent-data

# AWS region (for S3)
AWS_REGION=us-east-1

# For local MinIO development (comment out for AWS S3):
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# ===================
# AWS SSM Parameters (for deployed Lambda)
# ===================
# Note: These are stored in AWS SSM Parameter Store, not in .env
# Required when deploying to AWS:
#
# /sprint-poc/dev/claude-api-key     - Anthropic API key for Claude
# /sprint-poc/dev/jira-board-id      - Jira board ID to analyze
# /sprint-poc/dev/refinement-doc-id  - Google Doc ID for refinement notes
# /sprint-poc/dev/tech-design-doc-id - Google Doc ID for tech design
# /sprint-poc/dev/slack-webhook-url  - Slack webhook URL for alerts
