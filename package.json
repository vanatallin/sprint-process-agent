{
  "name": "sprint-agent",
  "version": "0.1.0",
  "description": "AI-powered sprint monitoring and ticket quality checking agent",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules --ignore backend/node_modules --ignore coverage",
    "format": "prettier --write 'src/**/*.{ts,js,vue,css,json}'",
    "format:check": "prettier --check 'src/**/*.{ts,js,vue,css,json}'",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json",
    "prepare": "husky install",
    "precommit": "lint-staged",
    "validate": "npm run lint && npm run format:check && npm run test"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "chart.js": "^4.4.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.4.0",
    "@commitlint/config-conventional": "^18.4.0",
    "@eslint/js": "^9.39.4",
    "@types/eslint": "^9.6.1",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-functional": "^9.0.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^8.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^23.0.0",
    "lint-staged": "^15.2.0",
    "markdownlint-cli": "^0.39.0",
    "postcss": "^8.4.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/sprint-agent.git"
  },
  "keywords": [
    "sprint",
    "agile",
    "ai",
    "claude",
    "jira",
    "automation",
    "analysis"
  ],
  "author": "Your Team",
  "license": "Apache-2.0"
}
